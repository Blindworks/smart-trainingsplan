<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="011-add-activity-metrics" author="system">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="activity_metrics"/></not>
        </preConditions>

        <createTable tableName="activity_metrics">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="completed_training_id" type="BIGINT">
                <constraints nullable="false" unique="true"
                             foreignKeyName="fk_activity_metrics_completed_training"
                             references="completed_trainings(id)"/>
            </column>
            <column name="zones_unknown" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="z1_min" type="DOUBLE"/>
            <column name="z2_min" type="DOUBLE"/>
            <column name="z3_min" type="DOUBLE"/>
            <column name="z4_min" type="DOUBLE"/>
            <column name="z5_min" type="DOUBLE"/>
            <column name="hr_data_coverage" type="DOUBLE"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
