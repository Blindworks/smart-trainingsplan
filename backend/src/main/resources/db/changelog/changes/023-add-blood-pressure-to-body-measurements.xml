<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="023-create-blood-pressure-measurements" author="dev">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="blood_pressure_measurements"/></not>
        </preConditions>

        <createTable tableName="blood_pressure_measurements">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_bp_measurements_user"
                             references="users(id)"/>
            </column>
            <column name="measured_at" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="systolic_pressure" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="diastolic_pressure" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="pulse_at_measurement" type="INT"/>
            <column name="notes" type="VARCHAR(500)"/>
        </createTable>

        <createIndex tableName="blood_pressure_measurements"
                     indexName="idx_bp_measurements_user_date">
            <column name="user_id"/>
            <column name="measured_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
