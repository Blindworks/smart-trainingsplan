<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="009-create-body-measurements" author="dev">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="body_measurements"/>
            </not>
        </preConditions>
        <createTable tableName="body_measurements">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_body_measurements_user"
                             references="users(id)"/>
            </column>
            <column name="measured_at" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="weight_kg" type="DOUBLE"/>
            <column name="fat_percentage" type="DOUBLE"/>
            <column name="water_percentage" type="DOUBLE"/>
            <column name="muscle_mass_kg" type="DOUBLE"/>
            <column name="bone_mass_kg" type="DOUBLE"/>
            <column name="visceral_fat_level" type="INT"/>
            <column name="metabolic_age" type="INT"/>
            <column name="bmi" type="DOUBLE"/>
            <column name="notes" type="VARCHAR(500)"/>
        </createTable>

        <createIndex tableName="body_measurements" indexName="idx_body_measurements_user_date">
            <column name="user_id"/>
            <column name="measured_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
