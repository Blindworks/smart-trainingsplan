<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="041-1" author="liquibase">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="training_plans"/>
            <not><columnExists tableName="training_plans" columnName="competition_type"/></not>
        </preConditions>
        <addColumn tableName="training_plans">
            <column name="competition_type" type="VARCHAR(50)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
