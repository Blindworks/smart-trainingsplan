<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="007-create-body-metrics" author="dev">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="body_metrics"/>
            </not>
        </preConditions>
        <createTable tableName="body_metrics">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_body_metrics_user"
                             references="users(id)"/>
            </column>
            <column name="metric_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="value" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="unit" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="recorded_at" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="source_activity_id" type="BIGINT"/>
        </createTable>

        <createIndex tableName="body_metrics" indexName="idx_body_metrics_user_type_date">
            <column name="user_id"/>
            <column name="metric_type"/>
            <column name="recorded_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
