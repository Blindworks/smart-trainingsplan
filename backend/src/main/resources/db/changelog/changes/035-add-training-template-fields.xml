<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="035-add-training-template-fields" author="trainingsplan">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="trainings" columnName="week_number"/>
            </not>
        </preConditions>
        <addColumn tableName="trainings">
            <column name="week_number" type="INT"/>
            <column name="day_of_week" type="VARCHAR(10)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
