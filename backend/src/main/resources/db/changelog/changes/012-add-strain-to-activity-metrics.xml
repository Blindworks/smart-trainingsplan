<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="012-add-strain-to-activity-metrics" author="system">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="activity_metrics" columnName="raw_load"/></not>
        </preConditions>

        <addColumn tableName="activity_metrics">
            <column name="raw_load" type="DOUBLE"
                    remarks="Weighted sum of zone minutes: Z1*1 + Z2*2 + Z3*3 + Z4*5 + Z5*8"/>
            <column name="strain21" type="DOUBLE"
                    remarks="Exponentially compressed load on 0-21 scale: 21*(1-exp(-rawLoad/k))"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
