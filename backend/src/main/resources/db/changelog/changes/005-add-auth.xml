<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="007" author="auth-migration">
        <addColumn tableName="users">
            <column name="password_hash" type="VARCHAR(255)" defaultValue="CHANGEME">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="008" author="auth-migration">
        <addColumn tableName="competitions">
            <column name="user_id" type="BIGINT">
                <constraints nullable="true" foreignKeyName="fk_competition_user" references="users(id)"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="009" author="auth-migration">
        <addColumn tableName="completed_trainings">
            <column name="user_id" type="BIGINT">
                <constraints nullable="true" foreignKeyName="fk_completed_training_user" references="users(id)"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
