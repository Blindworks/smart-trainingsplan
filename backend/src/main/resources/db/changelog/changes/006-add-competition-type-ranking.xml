<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="006-add-competition-type-ranking" author="dev">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="competitions" columnName="type"/>
            </not>
        </preConditions>
        <addColumn tableName="competitions">
            <column name="type" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>

    <changeSet id="007-add-competition-ranking" author="dev">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="competitions" columnName="ranking"/>
            </not>
        </preConditions>
        <addColumn tableName="competitions">
            <column name="ranking" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
