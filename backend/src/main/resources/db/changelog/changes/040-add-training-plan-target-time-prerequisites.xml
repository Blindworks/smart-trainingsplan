<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="040-add-training-plan-target-time" author="claude">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="training_plans" columnName="target_time"/>
            </not>
        </preConditions>
        <addColumn tableName="training_plans">
            <column name="target_time" type="VARCHAR(20)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="040b-add-training-plan-prerequisites" author="claude">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="training_plans" columnName="prerequisites"/>
            </not>
        </preConditions>
        <addColumn tableName="training_plans">
            <column name="prerequisites" type="TEXT">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
