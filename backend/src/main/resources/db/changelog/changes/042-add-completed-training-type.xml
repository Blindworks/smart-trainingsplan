<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="042-add-completed-training-type" author="system">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="completed_trainings" columnName="training_type"/>
            </not>
        </preConditions>
        <addColumn tableName="completed_trainings">
            <column name="training_type" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
