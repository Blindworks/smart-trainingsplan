<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="045-create-ai-training-plan" author="system">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="ai_training_plan"/></not>
        </preConditions>
        <createTable tableName="ai_training_plan">
            <column name="id" type="CHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_ai_plan_user"
                    references="users(id)"/>
            </column>
            <column name="week_start_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="model_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="model_version" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="DRAFT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="045-create-ai-training-day" author="system">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="ai_training_day"/></not>
        </preConditions>
        <createTable tableName="ai_training_day">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="plan_id" type="CHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_ai_day_plan"
                    references="ai_training_plan(id)"/>
            </column>
            <column name="date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="day_index" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="045-create-ai-training-workout" author="system">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="ai_training_workout"/></not>
        </preConditions>
        <createTable tableName="ai_training_workout">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="day_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_ai_workout_day"
                    references="ai_training_day(id)"/>
            </column>
            <column name="type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="target_zone" type="VARCHAR(100)"/>
            <column name="duration_minutes" type="INT"/>
            <column name="description" type="TEXT"/>
            <column name="structure_json" type="TEXT"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
