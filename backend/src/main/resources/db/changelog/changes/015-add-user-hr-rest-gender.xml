<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="015-add-user-hr-rest-gender" author="system">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="users" columnName="hr_rest"/></not>
        </preConditions>

        <addColumn tableName="users">
            <column name="hr_rest" type="INT"
                    remarks="Resting heart rate in bpm; required for TRIMP calculation"/>
            <column name="gender" type="VARCHAR(10)"
                    remarks="MALE or FEMALE; determines Bannister k coefficient (1.92/1.67)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
